worker_processes auto;
events {
    worker_connections 2048; # Tuning untuk high traffic
}

http {
    # Caching setup
    proxy_cache_path /var/cache/nginx/parking_cache levels=1:2 keys_zone=PARKING_CACHE:10m inactive=60m max_size=1g;

    upstream backend_api {
        server api:3000;
    }

    server {
        listen 80;

        location /api/v1/parking-zones {
            proxy_cache PARKING_CACHE;
            proxy_cache_valid 200 30m;
            
            # Tambahkan header untuk monitoring saat stress-test
            add_header X-Cache-Status $upstream_cache_status;

            # Tuning Buffer
            proxy_buffer_size 16k;
            proxy_buffers 4 32k;
            
            proxy_pass http://backend_api;
        }
    }
}